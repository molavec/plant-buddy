{
  "name": "plant-buddy-api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prestart": "yarn lint",
    "start": "NODE_ENV=development ts-node ./bin/www",
    "start:prod": "NODE_ENV=production ts-node ./bin/www",
    "prebuild": "yarn lint",
    "build": "tsc --project ./",
    "deploy": "scp -r ./api raspberry:/opt",
    "lint": "eslint '*/**/*.{js,jsx,ts,tsx}' --quiet --fix"
  },
  "dependencies": {
    "cookie-parser": "~1.4.3",
    "cors": "^2.8.4",
    "debug": "~4.3.1",
    "express": "~4.17.1",
    "http-errors": "~1.8.0",
    "jade": "~1.11.0",
    "morgan": "~1.10.0",
    "rotating-file-stream": "^2.1.5",
    "socket.io": "^4.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.2",
    "@types/debug": "^4.1.5",
    "@types/express": "^4.17.11",
    "@types/http-errors": "^1.8.0",
    "@types/morgan": "^1.9.2",
    "@types/node": "^14.14.41",
    "@typescript-eslint/eslint-plugin": "^4.22.0",
    "@typescript-eslint/parser": "^4.22.0",
    "eslint": "^7.24.0",
    "eslint-config-prettier": "^8.2.0",
    "eslint-plugin-prettier": "^3.4.0",
    "nodemon": "^2.0.7",
    "prettier": "^2.2.1",
    "ts-node": "^9.1.1",
    "typescript": "^4.2.4"
  }
}
